# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-strong-random-string-here

# Set to your deployed URL in production (Vercel sets NEXTAUTH_URL automatically)
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# Injected automatically by the Prisma Postgres Vercel Marketplace integration.
# For local dev: copy the values from Vercel → Settings → Env Vars into .env.local
POSTGRES_URL=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require
# Optional: direct (non-pooled) URL used by prisma migrate — also injected by the integration
# POSTGRES_URL_NON_POOLING=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require

# ─── File Storage ────────────────────────────────────────────────────────────
# Vercel Blob — add Blob storage in the Vercel dashboard → Storage → Create Store
# Token is injected automatically when Blob storage is linked to the project.
# Leave unset locally — photos save to public/uploads/ as fallback.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
