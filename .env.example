# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-a-strong-random-string-here

# Set to your deployed URL in production (Vercel sets NEXTAUTH_URL automatically)
NEXTAUTH_URL=http://localhost:3000

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Free options: https://neon.tech  |  https://supabase.com
# Vercel Postgres: add it in the Vercel dashboard → Storage → Create Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── File Storage ────────────────────────────────────────────────────────────
# Vercel Blob — add Blob storage in the Vercel dashboard → Storage → Create Store
# Token is injected automatically when Blob storage is linked to the project.
# Leave unset locally — photos save to public/uploads/ as fallback.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
