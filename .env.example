# Copy this file to .env.local and fill in the values for local development.
# On Vercel, POSTGRES_URL is injected automatically when you add Prisma Postgres storage.

# Required: any long random string (used to sign login sessions)
NEXTAUTH_SECRET=change-this-to-something-secret

# Required: injected automatically by Vercel when you add a Prisma Postgres database
POSTGRES_URL=postgres://user:password@db.prisma.io:5432/postgres?sslmode=require

# Optional: for photo uploads in production (injected when you add Vercel Blob storage)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── File Storage ────────────────────────────────────────────────────────────
# Vercel Blob — add Blob storage in the Vercel dashboard → Storage → Create Store
# Token is injected automatically when Blob storage is linked to the project.
# Leave unset locally — photos save to public/uploads/ as fallback.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
